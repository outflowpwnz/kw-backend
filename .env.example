# ── PostgreSQL (используется docker-compose) ──────────────────────────────
POSTGRES_USER=karpenko
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=karpenko_wedding

# ── Локальная разработка (без Docker) ─────────────────────────────────────
# DATABASE_URL=postgresql://karpenko:change_me_strong_password@localhost:5432/karpenko_wedding

# ── JWT (генерировать: openssl rand -hex 32) ──────────────────────────────
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret

# ── Admin ──────────────────────────────────────────────────────────────────
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_strong_password

# ── App ────────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Cookie domain (для cross-subdomain auth, напр. .example.com) ───────────
# COOKIE_DOMAIN=
